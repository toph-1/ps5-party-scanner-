#!/bin/bash

# ===============================
# PS5 Endpoint Tracker
# ===============================

if [ "$EUID" -ne 0 ]; then
    echo "Run with: sudo ./endpoint_tracker.sh"
    exit 1
fi

# Install tcpdump if missing
if ! command -v tcpdump >/dev/null 2>&1; then
    echo "Installing tcpdump..."
    apt update && apt install -y tcpdump
fi

read -p "Enter PS5 IP: " PS5_IP

# Auto detect interface
IFACE=$(ip route | grep default | awk '{print $5}')
[ -z "$IFACE" ] && IFACE="any"

clear
echo "🎮 PS5 Endpoint Tracker"
echo "Tracking: $PS5_IP"
echo "Interface: $IFACE"
echo "Press CTRL+C to stop"
echo "======================================"

# Temp storage
TMP_FILE="/tmp/ps5_ips.txt"
> "$TMP_FILE"

tcpdump -i $IFACE host $PS5_IP -nn -l 2>/dev/null | while read line; do

    # Extract IPs from packet line
    IPS=$(echo "$line" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}')

    for ip in $IPS; do
        if [ "$ip" != "$PS5_IP" ]; then
            # Add if new
            if ! grep -q "$ip" "$TMP_FILE"; then
                echo "$ip" >> "$TMP_FILE"

                clear
                echo "🎮 PS5 Endpoint Tracker"
                echo "Time: $(date)"
                echo "======================================"

                echo "🌐 Unique IPs:"
                cat "$TMP_FILE"

                echo ""
                echo "➕ New IP detected: $ip"
                echo "======================================"
            fi
        fi
    done

done
