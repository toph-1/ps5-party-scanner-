#!/bin/bash

clear
echo "🎮 PS5 Party Fix Tool (P2P Focused)"
echo "==================================="

# Detect connection type
IFACE=$(ip route | grep default | awk '{print $5}')
if [[ "$IFACE" == wl* ]]; then
  echo "⚠ You are on WiFi"
  echo "👉 Recommendation: Use Ethernet for stable parties"
else
  echo "✔ Using Ethernet"
fi

# Internet check
echo -e "\n[1] Internet Test..."
ping -c 1 google.com >/dev/null 2>&1 && echo "✔ Internet OK" || echo "✖ No Internet"

# NAT hint
LOCAL=$(hostname -I | awk '{print $1}')
PUBLIC=$(curl -s ifconfig.me)
echo -e "\n[2] NAT Check:"
if [[ "$LOCAL" != "$PUBLIC" ]]; then
  echo "⚠ You are behind NAT (likely NAT Type 3)"
  echo "👉 Parties may disconnect or fail to join"
else
  echo "✔ NAT seems open"
fi

# Party ports test
echo -e "\n[3] Party Ports Test (TCP 3478-3479)..."
for PORT in 3478 3479; do
  timeout 2 bash -c "echo > /dev/tcp/playstation.com/$PORT" 2>/dev/null && \
    echo "✔ TCP $PORT reachable" || echo "✖ TCP $PORT blocked"
done

echo -e "\n[!] UDP 3478-3479 and 49152-65535 cannot be directly tested from bash."
echo "Make sure UPnP is enabled or ports are forwarded on your router."

# Step-by-step guidance
echo -e "\n[4] Recommended Fixes:"
echo "1. Use Ethernet instead of WiFi"
echo "2. Enable UPnP on your router (T-Mobile gateways: check 'UPnP' in settings)"
echo "3. Set DNS manually on PS5:"
echo "   - Primary DNS: 8.8.8.8"
echo "   - Secondary DNS: 1.1.1.1"
echo "4. Restart router and PS5 after changes"
echo "5. If still blocked: T-Mobile CGNAT is preventing full P2P"
echo "   - Options: Use a VPN that supports port forwarding OR switch to ISP with public IP"

echo -e "\n==============================="
echo "Done. Follow the above steps for stable party connections."
