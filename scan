#!/bin/bash

clear
echo "🎮 PS5 Passive Network Check"
echo "==========================="

# Get local IP

echo -e "\n[1] Local IP:"
hostname -I

# Get public IP

echo -e "\n[2] Public IP:"
curl -s ifconfig.me && echo ""

# Check if behind NAT (simple hint)

echo -e "\n[3] NAT Check:"
LOCAL_IP=$(hostname -I | awk '{print $1}')
PUBLIC_IP=$(curl -s ifconfig.me)

if [[ "$LOCAL_IP" == "$PUBLIC_IP" ]]; then
echo "✔ Likely Open NAT (rare)"
else
echo "⚠ Behind NAT (normal for home networks)"
fi

# Check internet

echo -e "\n[4] Internet:"
ping -c 1 google.com >/dev/null 2>&1 && 
echo "✔ Online" || echo "✖ Offline"

# Show useful advice

echo -e "\n[5] Tips:"
echo "- For PS5 parties, aim for NAT Type 2"
echo "- Enable UPnP in your router"
echo "- Or forward ports: 3478-3480"
echo "- Use Ethernet if possible"

echo -e "\n==========================="
echo "Done."
