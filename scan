#!/bin/bash

if [ "$EUID" -ne 0 ]; then
    echo "Run with sudo"
    exit 1
fi

echo "🎮 PS5 VPN Fix (Safe Mode)"

# Ask for PS5 IP
read -p "Enter PS5 IP: " PS5_IP

# Detect interfaces
WIFI_IFACE=$(ip route | grep default | awk '{print $5}')
VPN_IFACE="tun0"

echo "WiFi Interface: $WIFI_IFACE"

# Enable forwarding
sysctl -w net.ipv4.ip_forward=1 >/dev/null

# Clean old rules (prevents breakage)
iptables -t nat -F
iptables -F

# Only route PS5 traffic through VPN
iptables -t nat -A POSTROUTING -s $PS5_IP -o $VPN_IFACE -j MASQUERADE

# Allow forwarding
iptables -A FORWARD -s $PS5_IP -o $VPN_IFACE -j ACCEPT
iptables -A FORWARD -d $PS5_IP -i $VPN_IFACE -j ACCEPT

echo "✅ Done"
echo "Your PC WiFi should still work"
echo "PS5 traffic is now routed through VPN"
