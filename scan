#!/bin/bash
# ========================================
# PS5 Party Port Checker & Configuration
# ========================================

clear
echo "🎮 PS5 Party P2P Port Checker"
echo "======================================"

# 1️⃣ Detect network interface
IFACE=$(ip route | grep default | awk '{print $5}')
IP_ADDR=$(ip addr show $IFACE | grep "inet " | awk '{print $2}' | cut -d/ -f1)
echo -e "\n[1] Current Network Interface: $IFACE"
echo "Local IP: $IP_ADDR"

# 2️⃣ Detect PS5 IP
read -p "Enter your PS5 IP (check network settings on PS5): " PS5_IP
if [[ ! $PS5_IP =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "✖ Invalid IP"
    exit 1
fi
echo "PS5 IP: $PS5_IP"

# 3️⃣ Check NAT hint
PUBLIC_IP=$(curl -s ifconfig.me)
echo -e "\n[2] NAT Check:"
if [[ "$IP_ADDR" == "$PUBLIC_IP" ]]; then
    echo "✔ NAT seems open"
else
    echo "⚠ You are behind NAT (likely NAT Type 3)"
fi

# 4️⃣ Test PS5 Party Ports
echo -e "\n[3] Testing PS5 Party Ports (TCP 3478, 3479)..."
PORTS_TCP=(3478 3479)
i=1
for PORT in "${PORTS_TCP[@]}"; do
    timeout 2 bash -c "echo > /dev/tcp/$PS5_IP/$PORT" 2>/dev/null && \
    echo "$i) TCP $PORT: ✔ Open" || echo "$i) TCP $PORT: ✖ Blocked"
    ((i++))
done

# UDP Ports (cannot test directly, just advise)
echo -e "\n[4] UDP Ports for P2P Party (3478-3479, 49152-65535)"
echo "Cannot test UDP directly. Ensure UPnP is enabled or ports forwarded."
echo "Check your router/firewall configuration."

# 5️⃣ Confirm IP forwarding and firewall
echo -e "\n[5] Ubuntu Configuration Check:"
if [ $(sysctl net.ipv4.ip_forward | awk '{print $3}') -eq 1 ]; then
    echo "✔ IP forwarding enabled"
else
    echo "✖ IP forwarding disabled"
    echo "  Run: sudo sysctl -w net.ipv4.ip_forward=1"
fi

echo "Check firewall (iptables) to ensure ports 3478-3479 and 49152-65535 are forwarded to PS5 IP."
echo "For UDP forwarding on Ubuntu, use iptables rules or a VPN."

# Final message
echo -e "\n==============================="
echo "✅ PS5 Party Port Check Complete"
echo "Follow the guidance above to fix blocked ports."
